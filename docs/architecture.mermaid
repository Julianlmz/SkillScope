flowchart TD
    subgraph INPUT["📦 Fuente de Datos"]
        A1["linkedin_job_postings.csv\n1,348,454 registros"]
        A2["job_skills.csv\n1,296,381 registros"]
    end

    subgraph EXTRACT["1️⃣  EXTRACT — src/ingestion/extract.py"]
        B1["extract_jobs()"]
        B2["extract_skills()"]
