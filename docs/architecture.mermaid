    subgraph ORCHESTRATION["⚙️  Orquestación"]
        E1["src/pipeline/main.py\n--mode=full/extract/transform/load"]
        E2["Makefile\nmake run-full"]
    end

    A1 --> B1
    A2 --> B2
    B1 --> C1
    B2 --> C4
    C1 --> C2 --> C3
    C3 --> D2
    C4 --> D3
    D2 --> D1
    D3 --> D1
    E2 --> E1 --> EXTRACT